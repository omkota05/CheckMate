# Copy this file to ".env" in the project root (same folder as package.json).
# Put your personal Gemini API key after the = sign. Never commit ".env".

GEMINI_API_KEY=

# Optional: production or ngrok HTTPS URL. In local `npm run dev`, the app uses `/api` on port 8080
# (Vite proxies to FastAPI on 127.0.0.1:8000) so phones do not need to reach port 8000 directly.
# VITE_API_URL=

# Backend (same machine as Vite):
#   cd backend && python -m uvicorn main:app --reload --port 8000
